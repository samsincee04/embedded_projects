@implementation DataReceiver

+ (instancetype)shared{
    static DataReceiver *single = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        single = [[DataReceiver alloc] _init];
    });
    return single;
}

- (instancetype)_init {
    if (self = [super init]) {
        // BLE command serialization queue (prevents command overlap/out-of-order)
        self.bleCmdQueue = dispatch_queue_create("com.sdkdemo.bleCmdQueue", DISPATCH_QUEUE_SERIAL);

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(receiveBleData:)
                                                     name:CEProductK6ReceiveDataNoticeKey
                                                   object:nil];

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(bluetoothStatusChanged:)
                                                     name:ProductStatusChangeNoticeKey
                                                   object:nil];

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(appWillResignActive)
                                                     name:UIApplicationWillResignActiveNotification
                                                   object:nil];

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(appWillTerminate)
                                                     name:UIApplicationWillTerminateNotification
                                                   object:nil];

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(appDidEnterBackground)
                                                     name:UIApplicationDidEnterBackgroundNotification
                                                   object:nil];

        [[NSNotificationCenter defaultCenter] addObserver:self
                                                 selector:@selector(appWillEnterForeground)
                                                     name:UIApplicationWillEnterForegroundNotification
                                                   object:nil];

        self.motionBuffer = [NSMutableArray array];
        self.heartHistoryJSON = [NSMutableArray array];
        self.spo2HistoryJSON  = [NSMutableArray array];
        self.lastFlushTs = 0;
        self.motionSegmentId = 0;

        self.recordingActive = NO;
        self.wantNightRunning = NO;

        self.motionSessionActive = NO;
        self.motionSessionStartTs = 0;
        self.lastMotionPacketTs = 0;

        self.realtimeCaptureEnabled = NO;
        self.vitalsCycleRunning = NO;

        self.nightSessionRunning = NO;
        self.motionWindowActive = NO;
        self.bleConnected = NO;
        
        self.lastVitalsPacketTs = 0;
        self.vitalsWatchdogTimer = nil;
        self.lastAnyPacketTs = 0;
        self.sessionWatchdogTimer = nil;
        self.sessionResetInProgress = NO;
        
        self.fileIOQueue = dispatch_queue_create("com.sdkdemo.fileIOQueue", DISPATCH_QUEUE_SERIAL);
    }
    return self;
}

#pragma mark - BLE Command Helper

- (void)bleSendCmd:(id)cmd label:(NSString *)label {
    if (!cmd) return;
    dispatch_async(self.bleCmdQueue ?: dispatch_get_main_queue(), ^{
        [[CEProductK6 shareInstance] sendCmdToDevice:cmd complete:^(NSError *error) {
            if (error) {
                DLOG(@"[BLE CMD] %@ failed: %@", label ?: @"cmd", error);
            }
        }];
    });
}

#pragma mark - Public Session API
// Initializes a new recording session
// Resets buffers, counters, and session metadata
- (void)startNightSession {

    self.wantNightRunning = YES;

    self.currentSessionId =
        [NSString stringWithFormat:@"night_%@",
         @((long)[[NSDate date] timeIntervalSince1970])];
    
    self.combinedCycle = 1; // start at cycle 1 for this session

    // marker that captures intended start time
    [self writeSessionStartMarker];

    //Reset motion session state
    self.motionSegmentId = 0;
    self.motionSessionStartTs = 0;
    self.motionSessionActive = NO;
    self.lastFlushTs = 0;
    self.motionSampleCounter = 0;
    self.lastMotionPacketTs = 0;

    //clear buffers
    [self.motionBuffer removeAllObjects];
    [self.heartHistoryJSON removeAllObjects];
    [self.spo2HistoryJSON removeAllObjects];

    // Session on
    self.recordingActive = YES;
    self.motionWindowActive = NO;

    // Keep receiver gate ON for the whole night session
    [self enableRealtimeCapture];

    // Keep HR_CONTROL ON for the whole night session
    CE_HRControlCmd *hrControlOn =
        [[CE_HRControlCmd alloc] initWithOnoff:1 type:HR_CONTROL_TYPE_HR];
    [self bleSendCmd:hrControlOn label:@"HR_CONTROL ON"];

    DLOG(@"[SESSION] Started %@", self.currentSessionId);

    // Watchdogs + liveness
    [self startMotionWatchdog];
    self.lastVitalsPacketTs = 0;
    [self startVitalsWatchdog];
    
    self.lastAnyPacketTs = [[NSDate date] timeIntervalSince1970]; // grace anchor at session start
    self.sessionResetInProgress = NO;
    [self startSessionLivenessWatchdog];
    
    // Sync device and start loop
    [self syncData];

    // Start the night pipeline a couple seconds after sync finishes
    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(3.0 * NSEC_PER_SEC)),
                   dispatch_get_main_queue(), ^{
        if (!self.recordingActive) return;
        [self startNightCycleTimer];
    });
}


- (void)stopNightSession {
    DLOG(@"[SESSION] Stopping %@", self.currentSessionId);

    // One end timestamp used everywhere (marker + metadata)
    NSTimeInterval endTs = [[NSDate date] timeIntervalSince1970];

    // Write session_end marker using the same endTs
    [self writeSessionEndMarkerWithReason:@"user_stop" endTs:endTs];

    // Also write metadata JSON (same endTs)
    [self writeSessionMetadataWithEndTs:endTs];

    self.wantNightRunning = NO;
    self.recordingActive = NO;

    // Stop scheduler
    [self stopNightCycleTimer];

    // Turn OFF device streams safely
    [self night_motion:NO];
    [self forceStopVitalsNow];

    // Stop watchdogs
    [self stopMotionWatchdog];
    [self flushMotionBatch];
    [self stopSessionLivenessWatchdog];

    // Export vitals JSONs
    [self exportVitalsJSONToFiles];

    [self stopHeartbeat];

    self.motionSessionActive = NO;

    // HR_CONTROL OFF at end of session
    CE_HRControlCmd *hrControlOff =
        [[CE_HRControlCmd alloc] initWithOnoff:0 type:HR_CONTROL_TYPE_HR];
    [self bleSendCmd:hrControlOff label:@"HR_CONTROL OFF"];

    // Receiver gate off
    [self disableRealtimeCapture];

    [self stopVitalsWatchdog];

    self.lastAnyPacketTs = 0;
    self.sessionResetInProgress = NO;
}

#pragma mark - Session Markers (Start/End)

- (void)writeSessionStartMarker {
    if (!self.currentSessionId || self.currentSessionId.length == 0) return;

    NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
    self.sessionStartTs = now;

    NSDictionary *payload = @{
        @"type": @"session_start",
        @"sessionId": self.currentSessionId,
        @"startTs": @(now),
        @"reason": @"user_start"
    };

    NSError *err = nil;
    NSData *data = [NSJSONSerialization dataWithJSONObject:payload
                                                   options:NSJSONWritingPrettyPrinted
                                                     error:&err];
    if (err || !data) {
        DLOG(@"[SESSION MARKER] Failed to build start marker JSON: %@", err);
        return;
    }

    NSString *json = [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
    NSString *filename = [NSString stringWithFormat:@"session_start_%@.json", self.currentSessionId];

    [self writeJSONString:json toFilename:filename];
    DLOG(@"[SESSION MARKER] Wrote start marker %@", filename);
}

- (void)writeSessionEndMarkerWithReason:(NSString *)reason endTs:(NSTimeInterval)endTs {
    if (!self.currentSessionId || self.currentSessionId.length == 0) return;

    NSTimeInterval ts = (endTs > 0) ? endTs : [[NSDate date] timeIntervalSince1970];
    NSString *why = (reason.length > 0) ? reason : @"user_stop";

    NSMutableDictionary *payload = [@{
        @"type": @"session_end",
        @"sessionId": self.currentSessionId,
        @"endTs": @(ts),
        @"reason": why
    } mutableCopy];

    // include intended duration if start marker was written
    if (self.sessionStartTs > 0) {
        payload[@"intendedDurationSec"] = @(ts - self.sessionStartTs);
    }

    NSError *err = nil;
    NSData *data = [NSJSONSerialization dataWithJSONObject:payload
                                                   options:NSJSONWritingPrettyPrinted
                                                     error:&err];
    if (err || !data) {
        DLOG(@"[SESSION MARKER] Failed to build end marker JSON: %@", err);
        return;
    }

    NSString *json = [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
    NSString *filename = [NSString stringWithFormat:@"session_end_%@.json", self.currentSessionId];

    [self writeJSONString:json toFilename:filename];
    DLOG(@"[SESSION MARKER] Wrote end marker %@", filename);
}

# pragma mark - App Lifecycle

- (void)appWillResignActive {
    DLOG(@"[APP] Will resign active — flushing motion buffer");
    [self flushMotionBatch];
}

- (void)appWillTerminate {
    DLOG(@"[APP] Will terminate — flushing motion buffer");
    [self flushMotionBatch];
}

- (void)appDidEnterBackground {
    DLOG(@"[APP] Did enter background -  flushing");
    
    // This avoids relying on timer-based flushes while iOS may throttle background execution.
        if (self.recordingActive) {
            [self flushMotionBatch];
            self.lastFlushTs = [[NSDate date] timeIntervalSince1970]; // reset flush window anchor
        }
}

- (void)appWillEnterForeground {
    DLOG(@"[APP] Will enter foreground");
    if (self.recordingActive) {
            self.lastFlushTs = [[NSDate date] timeIntervalSince1970];
        }
}

#pragma mark - Combined TXT Guards

- (BOOL)shouldWriteCombinedRows {
    // Only when user explicitly started a night session
    // (wantNightRunning stays YES until Stop Night)
    if (!self.wantNightRunning) return NO;
    if (!self.recordingActive) return NO;

    // Must have a session id
    if (self.currentSessionId.length == 0) return NO;

    return YES;
}
#pragma mark - Night Command Guards


- (BOOL)nightCanSendCommands {
    return self.bleConnected && self.nightSessionRunning;
}

- (BOOL)nightCanSendStopCommands {
    // used for OFF commands (safe even after we flip flags)
    return YES;
}

#pragma mark - Night Device commands

// Motion ON/OFF
- (void)night_motion:(BOOL)on {

    // ON requires active night session; OFF should still be allowed during teardown.
    if (on) {
        if (![self nightCanSendCommands]) return;
    } else {
        if (![self nightCanSendStopCommands]) return;
    }

    CE_SendMotionCmd *cmd = [[CE_SendMotionCmd alloc] init];
    cmd.onoff = on ? 1 : 0;
    [[CEProductK6 shareInstance] sendCmdToDevice:cmd complete:nil];
    DLOG(@"[NIGHT] Motion %@", on ? @"ON" : @"OFF");
}

- (void)night_stopVitalsAll {
    // Do NOT stop vitals during an active night session.
    // Stopping vitals depends on timers to re-enable them, and iOS can pause those.
    // We will only stop vitals on stopNightSession.
    if (self.wantNightRunning || self.nightSessionRunning || self.recordingActive) {
        DLOG(@"[NIGHT] stopVitalsAll skipped (session running)");
        return;
    }

    // If we truly are not running, allow stop
    CE_SyncHeartO2Cmd *o2Off = [[CE_SyncHeartO2Cmd alloc] init];
    o2Off.status = 0;
    [self bleSendCmd:o2Off label:@"O2 OFF"];

    CE_SyncHeartRateCmd *hrOff = [[CE_SyncHeartRateCmd alloc] init];
    hrOff.status = 0;
    [self bleSendCmd:hrOff label:@"HR OFF"];

    DLOG(@"[NIGHT] stopVitalsAll: HR/O2 OFF");
}
- (void)night_spo2On {
    if (![self nightCanSendCommands]) return;
    self.nightPhase = NightPhaseSpO2;

    // receiver gate stays enabled for entire night session, but safe to ensure
    [self enableRealtimeCapture];

    // HR ON + O2 ON (HR_CONTROL already ON from startNightSession)
    CE_SyncHeartRateCmd *hrOn = [[CE_SyncHeartRateCmd alloc] init];
    hrOn.status = 1;
    [self bleSendCmd:hrOn label:@"HR ON (SpO2 phase)"];

    CE_SyncHeartO2Cmd *o2On = [[CE_SyncHeartO2Cmd alloc] init];
    o2On.status = 1;
    [self bleSendCmd:o2On label:@"O2 ON"];

    DLOG(@"[NIGHT] SpO2 ON (HR + O2; HR_CONTROL already ON)");
}

- (void)night_spo2Off {
    DLOG(@"[NIGHT] SpO2 OFF");
}

- (void)night_hrOn {
    if (![self nightCanSendCommands]) return;
    self.nightPhase = NightPhaseHR;

    [self enableRealtimeCapture];

    CE_SyncHeartO2Cmd *o2On = [[CE_SyncHeartO2Cmd alloc] init];
    o2On.status = 1;
    [self bleSendCmd:o2On label:@"O2 ON (HR phase)"];

    CE_SyncHeartRateCmd *hrOn = [[CE_SyncHeartRateCmd alloc] init];
    hrOn.status = 1;
    [self bleSendCmd:hrOn label:@"HR ON (HR phase)"];

    DLOG(@"[NIGHT] HR ON (HR only; HR_CONTROL already ON)");
}

- (void)night_hrOff {
    DLOG(@"[NIGHT] HR OFF");
}

- (void)forceStopVitalsNow {
    CE_SyncHeartO2Cmd *o2Off = [[CE_SyncHeartO2Cmd alloc] init];
    o2Off.status = 0;
    [self bleSendCmd:o2Off label:@"O2 OFF (force)"];

    CE_SyncHeartRateCmd *hrOff = [[CE_SyncHeartRateCmd alloc] init];
    hrOff.status = 0;
    [self bleSendCmd:hrOff label:@"HR OFF (force)"];

    DLOG(@"[NIGHT] forceStopVitalsNow: HR/O2 OFF");
}

#pragma mark - Night Loop Scheduler
/**
 Night loop state machine

 We use (nightPhase + nightToken) to manage the repeating loop.
 - nightPhase indicates which phase we are currently in.
 - nightToken invalidates any previously scheduled dispatch_after blocks.

 Phase transitions:
   SpO2 phase:
     - keep HR + O2 ON (night_spo2On)
     - after kNightSpO2Seconds -> transition to Motion phase
   Motion phase:
     - enable motionWindowActive
     - send motion ON
     - after kNightMotionSeconds -> transition to HR phase
   HR phase:
     - keep HR + O2 ON (night_hrOn)
     - after kNightHRSeconds -> transition back to SpO2
 */

- (void)startNightCycleTimer {
    if (self.nightSessionRunning) return;

    self.nightSessionRunning = YES;
    [self enableRealtimeCapture];
    self.nightToken += 1;
    uint64_t token = self.nightToken;

    self.motionWindowActive = NO;

    [self night_motion:NO];

    self.nightPhase = NightPhaseSpO2;
    [self night_spo2On];

    [self night_scheduleNextStepAfter:kNightSpO2Seconds token:token];
}
- (void)stopNightCycleTimer {
    self.nightSessionRunning = NO;
    self.nightToken += 1;
    self.motionWindowActive = NO;

    [self night_motion:NO];
    [self night_stopVitalsAll];

    DLOG(@"[NIGHT] Cycle stopped");
}

- (void)night_scheduleNextStepAfter:(NSTimeInterval)sec token:(uint64_t)token {
    __weak typeof(self) weakSelf = self;
    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(sec * NSEC_PER_SEC)),
                   dispatch_get_main_queue(), ^{
        __strong typeof(weakSelf) self = weakSelf;
        if (!self) return;
        if (!self.nightSessionRunning) return;
        if (self.nightToken != token) return;
        [self night_stepWithToken:token];
    });
}

- (void)night_stepWithToken:(uint64_t)token {
    if (!self.nightSessionRunning) return;
    if (self.nightToken != token) return;

    switch (self.nightPhase) {

        // SpO2 -> Motion
        case NightPhaseSpO2: {
            [self night_spo2Off];

            self.nightPhase = NightPhaseMotion;
            self.motionWindowActive = YES;

            __weak typeof(self) weakSelf = self;
            dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(2.0 * NSEC_PER_SEC)),
                           dispatch_get_main_queue(), ^{
                __strong typeof(weakSelf) self = weakSelf;
                if (!self || !self.nightSessionRunning) return;
                if (self.nightToken != token) return;
                if (self.nightPhase != NightPhaseMotion) return;
                [self night_motion:YES];
            });

            [self night_scheduleNextStepAfter:(2.0 + kNightMotionSeconds) token:token];
            break;
        }

        // Motion -> HR
        case NightPhaseMotion: {
            self.motionWindowActive = NO;
            [self night_motion:NO];

            // set phase now; HR ON will also set phase but this keeps the state consistent during the dead-time
            self.nightPhase = NightPhaseHR;

            __weak typeof(self) weakSelf = self;
            dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(2.0 * NSEC_PER_SEC)),
                           dispatch_get_main_queue(), ^{
                __strong typeof(weakSelf) self = weakSelf;
                if (!self || !self.nightSessionRunning) return;
                if (self.nightToken != token) return;
                if (self.nightPhase != NightPhaseHR) return;
                [self night_hrOn];
            });

            [self night_scheduleNextStepAfter:(2.0 + kNightHRSeconds) token:token];
            break;
        }

        // HR -> SpO2
        case NightPhaseHR: {
            [self night_hrOff];

            self.combinedCycle += 1;
            // set phase now; SpO2 ON will also set phase but keeps state consistent during dead-time
            self.nightPhase = NightPhaseSpO2;

            __weak typeof(self) weakSelf = self;
            dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(2.0 * NSEC_PER_SEC)),
                           dispatch_get_main_queue(), ^{
                __strong typeof(weakSelf) self = weakSelf;
                if (!self || !self.nightSessionRunning) return;
                if (self.nightToken != token) return;
                if (self.nightPhase != NightPhaseSpO2) return;
                [self night_spo2On];
            });

            [self night_scheduleNextStepAfter:(2.0 + kNightSpO2Seconds) token:token];
            break;
        }
    }
}

# pragma mark - Motion Normalization / Flush
// Converts raw motion dictionary into structured MotionRecord
// Adds timestamps, session delta, and metadata

- (MotionRecord *)normalizeMotion144:(NSDictionary *)data {

    NSDictionary *motion = data[@"data"];
    if (![motion isKindOfClass:[NSDictionary class]]) {
        return nil;
    }

    MotionRecord *record = [[MotionRecord alloc] init];
    record.deviceId = [self hashedDeviceId];
    
    NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
    record.timestamp = now;

    // Self-healing motion session start
    if (!self.motionSessionActive) {
        self.motionSessionStartTs = now;
        self.motionSessionActive = YES;
        record.deltaSeconds = 0;   // first packet anchor
    } else {
        record.deltaSeconds = now - self.motionSessionStartTs;
    }
    
    
    record.source = @"ios_sdk";
    record.datatype = 144;
    record.segmentId = self.motionSegmentId;

    record.x = [motion[@"x"] integerValue];
    record.y = [motion[@"y"] integerValue];
    record.speedThrow = [motion[@"speed_throw"] integerValue];

    return record;
}

// Flush 60-sec motion buffer to cloud(mock), CSV file
- (void)flushMotionBatch {
    if (self.motionBuffer.count == 0) return;
    
    NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
    NSLog(@"[BATCH] Flushing %lu motion records (%.2fs window)",
         (unsigned long)self.motionBuffer.count,
         now - self.lastFlushTs);

    // Cloud payload (array)
    NSMutableArray *jsonArray = [NSMutableArray arrayWithCapacity:self.motionBuffer.count];
    for (MotionRecord *r in self.motionBuffer) {
        [jsonArray addObject:[r toJSON]];
    }

    [self sendPayloadToCloud:@{
        @"records": jsonArray,
        @"count": @(jsonArray.count)
    }];

    //  CSV write (append all lines)
    NSMutableString *csvBlock = [NSMutableString string];
    for (MotionRecord *r in self.motionBuffer) {
        [csvBlock appendString:[r toCSV]];
    }

    NSString *header =
    @"device_id,timestamp,delta_seconds,source,datatype,segment_id,x,y,speed_throw\n";

    [self appendLine:csvBlock
          withHeader:header
              forType:DATA_TYPE_MOTION_DATA];

    // Clear buffer
    [self.motionBuffer removeAllObjects];
}

# pragma mark - BLE Receive Entry Point
// Main BLE packet entry point
// Routes packets based on DataType

- (void)receiveBleData:(NSNotification *)noti {

    NSDictionary *receiveData = noti.userInfo;
    if (!receiveData) return;

    NSLog(@"[RX] DataType(raw)=%@", receiveData[@"DataType"]);

    K6_DataFuncType dataFuncType =
        (K6_DataFuncType)[receiveData[@"DataType"] integerValue];
    DLOG(@"[DEBUG] DataType=%ld", (long)dataFuncType);

    id data = receiveData[@"Data"];
    NSLog(@"[RX] DataType=%@ DataClass=%@",
          receiveData[@"DataType"],
          NSStringFromClass([data class]));

    if (!data) return;

    if ([data isKindOfClass:[NSDictionary class]]) {
        NSLog(@"[RX] DataType=%@ keys=%@", receiveData[@"DataType"], [(NSDictionary *)data allKeys]);
    } else {
        NSLog(@"[RX] DataType=%@ dataClass=%@", receiveData[@"DataType"], NSStringFromClass([data class]));
    }

    switch (dataFuncType) {

        case DATA_TYPE_MOTION_DATA: {
            if (!self.recordingActive || !self.motionWindowActive) break;

            // touch liveness timestamps
            NSTimeInterval rxNow = [[NSDate date] timeIntervalSince1970];
            self.lastMotionPacketTs = rxNow;
            self.lastAnyPacketTs = rxNow;

            if (![data isKindOfClass:[NSDictionary class]]) break;
            NSDictionary *motion = ((NSDictionary *)data)[@"data"];
            if (![motion isKindOfClass:[NSDictionary class]]) break;

            self.motionSampleCounter++;
            if (self.motionSampleCounter % 3000 == 0) {
                NSLog(@"[MOTION144] sample x=%@ y=%@ speed=%@ (segment=%ld)",
                      motion[@"x"], motion[@"y"], motion[@"speed_throw"],
                      (long)self.motionSegmentId);
            }
            
            // Combined TXT row (ACCEL)
            NSString *ax = [NSString stringWithFormat:@"%ld", (long)[motion[@"x"] integerValue]];
            NSString *ay = [NSString stringWithFormat:@"%ld", (long)[motion[@"y"] integerValue]];
            NSString *az = [NSString stringWithFormat:@"%ld", (long)[motion[@"speed_throw"] integerValue]];

            [self appendCombinedRowWithTs:rxNow
                                    cycle:self.combinedCycle
                                     step:@"ACCEL"
                                      bpm:@"-"
                                   accelX:ax
                                   accelY:ay
                                   accelZ:az
                                     spo2:@"-"];

            MotionRecord *record = [self normalizeMotion144:(NSDictionary *)data];
            if (!record) break;

            [self.motionBuffer addObject:record];

            NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
            if (self.lastFlushTs == 0) self.lastFlushTs = now;

            if (now - self.lastFlushTs >= 60.0) {
                [self flushMotionBatch];
                self.lastFlushTs = now;
            }
            break;
        }

        case DATA_TYPE_REAL_SPORT:
        case DATA_TYPE_HISTORY_SPORT:
            break;

        case DATA_TYPE_REAL_HEART: {
            if (!self.realtimeCaptureEnabled) break;
            if (![data isKindOfClass:[NSDictionary class]]) break;

            NSDictionary *root = (NSDictionary *)data;

            id heartInfosObj = root[@"heartInfos"];
            if (!heartInfosObj) {
                NSDictionary *nested = root[@"data"];
                if ([nested isKindOfClass:[NSDictionary class]]) {
                    heartInfosObj = nested[@"heartInfos"];
                }
            }

            if (![heartInfosObj isKindOfClass:[NSArray class]] || ((NSArray *)heartInfosObj).count == 0) break;

            NSDictionary *latest = ((NSArray *)heartInfosObj).firstObject;
            if (![latest isKindOfClass:[NSDictionary class]]) break;

            NSInteger bpm = 0;
            if (latest[@"heartNum"]) bpm = [latest[@"heartNum"] integerValue];
            else if (latest[@"bpm"]) bpm = [latest[@"bpm"] integerValue];
            else if (latest[@"hr"]) bpm = [latest[@"hr"] integerValue];

            if (bpm <= 0) break;

            NSTimeInterval deviceTs = 0;
            if (latest[@"time"]) deviceTs = [latest[@"time"] doubleValue];

            NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
            NSTimeInterval tsToUse = now;
            
            if (deviceTs > 0 && fabs(deviceTs - now) < (7.0 * 24.0 * 60.0 * 60.0)) {
                tsToUse = deviceTs;
            }
            
            // Combined TXT row (BPM)
            [self appendCombinedRowWithTs:tsToUse
                                    cycle:self.combinedCycle
                                     step:@"BPM"
                                      bpm:[NSString stringWithFormat:@"%ld", (long)bpm]
                                  accelX:@"-"
                                  accelY:@"-"
                                  accelZ:@"-"
                                    spo2:@"-"];
            

        

            NSTimeInterval delta = 0;
            if (self.motionSessionActive) {
                NSTimeInterval d = tsToUse - self.motionSessionStartTs;
                delta = (d < 0) ? 0 : d;
            }

            NSDictionary *hrJSON = @{
                @"device_id": [self hashedDeviceId] ?: @"",
                @"timestamp": @(tsToUse),
                @"delta_seconds": @(delta),
                @"segment_id": @(self.motionSegmentId),
                @"bpm": @(bpm),
                @"phase": @(self.nightPhase)
            };

            // touch liveness timestamps (vitals + any)
            NSTimeInterval rxNow = [[NSDate date] timeIntervalSince1970];
            self.lastVitalsPacketTs = rxNow;
            self.lastAnyPacketTs = rxNow;

            NSLog(@"[HR PARSED] bpm=%ld phase=%ld", (long)bpm, (long)self.nightPhase);

            [self publishRealtimeHeartJSON:hrJSON];
            [self appendRolling:self.heartHistoryJSON sample:hrJSON];
            break;
        }

        case DATA_TYPE_REAL_O2: {
            if (!self.realtimeCaptureEnabled) break;
            if (![data isKindOfClass:[NSDictionary class]]) break;

            NSDictionary *o2Root = (NSDictionary *)data;
            id payload = o2Root[@"data"];

            NSDictionary *latest = nil;

            if ([payload isKindOfClass:[NSArray class]]) {
                NSArray *arr = (NSArray *)payload;
                if (arr.count > 0 && [arr[0] isKindOfClass:[NSDictionary class]]) {
                    latest = arr[0];
                }
            } else if ([payload isKindOfClass:[NSDictionary class]]) {
                latest = (NSDictionary *)payload;
            }

            if (![latest isKindOfClass:[NSDictionary class]]) break;

            id inner = latest[@"data"];
            if ([inner isKindOfClass:[NSArray class]]) {
                NSArray *innerArr = (NSArray *)inner;
                if (innerArr.count > 0 && [innerArr[0] isKindOfClass:[NSDictionary class]]) {
                    latest = innerArr[0];
                }
            } else if ([inner isKindOfClass:[NSDictionary class]]) {
                latest = (NSDictionary *)inner;
            }

            if (![latest isKindOfClass:[NSDictionary class]]) break;

            NSInteger spo2 = 0;
            if (latest[@"oxygen"]) spo2 = [latest[@"oxygen"] integerValue];
            else if (latest[@"spo2"]) spo2 = [latest[@"spo2"] integerValue];
            else if (latest[@"o2"]) spo2 = [latest[@"o2"] integerValue];

            NSTimeInterval deviceTs = 0;
            if (latest[@"time"]) deviceTs = [latest[@"time"] doubleValue];

            if (spo2 <= 0) break;

            NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
            NSTimeInterval tsToUse = now;
            if (deviceTs > 0 && fabs(deviceTs - now) < (7.0 * 24.0 * 60.0 * 60.0)) {
                tsToUse = deviceTs;
            }
            
            // Combined TXT row (SPO2)
            [self appendCombinedRowWithTs:tsToUse
                                    cycle:self.combinedCycle
                                     step:@"SPO2"
                                      bpm:@"-"
                                  accelX:@"-"
                                  accelY:@"-"
                                  accelZ:@"-"
                                    spo2:[NSString stringWithFormat:@"%ld", (long)spo2]];

            NSDictionary *o2JSON = @{
                @"device_id": [self hashedDeviceId] ?: @"",
                @"timestamp": @(tsToUse),
                @"segment_id": @(self.motionSegmentId),
                @"spo2": @(spo2),
                @"phase": @(self.nightPhase)
            };

            //  touch liveness timestamps (vitals + any)
            NSTimeInterval rxNow = [[NSDate date] timeIntervalSince1970];
            self.lastVitalsPacketTs = rxNow;
            self.lastAnyPacketTs = rxNow;

            static NSInteger o2Counter = 0;
            o2Counter++;
            if (o2Counter % 5 == 0) {
                DLOG(@"[SPO2 PARSED] spo2=%ld phase=%ld", (long)spo2, (long)self.nightPhase);
            }

            [self publishRealtimeSpO2JSON:o2JSON];
            [self appendRolling:self.spo2HistoryJSON sample:o2JSON];
            break;
        }

        default:
            break;
    }

    [NSNotificationCenter.defaultCenter postNotificationName:@"DataReceivceFinish" object:nil];
}
    
