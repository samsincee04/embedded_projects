@property (nonatomic, strong) NSString *currentSessionId;

// Controls whether motion packets are processed
@property (nonatomic, assign) BOOL recordingActive;

@property (nonatomic, assign) NSTimeInterval lastMotionPacketTs;
@property (nonatomic, strong) dispatch_source_t motionWatchdogTimer;
