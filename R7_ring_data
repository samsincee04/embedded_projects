static NSString * const kCombinedHeaderTSV =
    @"timestamp\tcycle\tstep\tbpm\taccel_x\taccel_y\taccel_z\tspo2\n";

- (NSString *)combinedPath {
    NSString *docs =
        NSSearchPathForDirectoriesInDomains(NSDocumentDirectory,
