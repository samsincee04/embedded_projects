- (void)startVitalsCycleEvery:(NSTimeInterval)periodSec vitalsWindow:(NSTimeInterval)windowSec {

    // periodSec controls "every X minutes"
    NSTimeInterval interval = (periodSec > 0) ? periodSec : 300.0;

    // If Start Night was never pressed, create a session id for vitals files
    if (!self.currentSessionId || self.currentSessionId.length == 0) {
        self.currentSessionId =
            [NSString stringWithFormat:@"vitals_%@",
             @((long)[[NSDate date] timeIntervalSince1970])];
    }

    // Clear previous vitals history so STOP exports only this run
    [self.heartHistoryJSON removeAllObjects];
    [self.spo2HistoryJSON removeAllObjects];
    

    self.vitalsCycleRunning = YES;
    [self startVitalsPollingEvery:interval];

    NSLog(@"[VITALS] started (poll every %.0fs) session=%@", interval, self.currentSessionId);
}

- (void)stopVitalsCycle {

    self.vitalsCycleRunning = NO;
    //self.vitalsMeasuring = NO;

    [self stopVitalsPolling];

    // stop device-side measurement (safe)
    CE_SyncHeartRateCmd *hrOff = [[CE_SyncHeartRateCmd alloc] init];
    hrOff.status = 0;
    [[CEProductK6 shareInstance] sendCmdToDevice:hrOff complete:nil];

    CE_SyncHeartO2Cmd *o2Off = [[CE_SyncHeartO2Cmd alloc] init];
    o2Off.status = 0;
    [[CEProductK6 shareInstance] sendCmdToDevice:o2Off complete:nil];

    CE_HRControlCmd *hrStop = [[CE_HRControlCmd alloc] initWithOnoff:0 type:HR_CONTROL_TYPE_HR];
    [[CEProductK6 shareInstance] sendCmdToDevice:hrStop complete:nil];

    [self disableRealtimeCapture];

    NSLog(@"[VITALS] stopVitalsCycle: HR_count=%lu O2_count=%lu",
          (unsigned long)self.heartHistoryJSON.count,
          (unsigned long)self.spo2HistoryJSON.count);

    // EXPORT NOW
    [self exportVitalsJSONToFiles];

    NSLog(@"[VITALS] stopped + exported JSONs");
}

static const NSTimeInterval kVitalsPollIntervalSec = 5.0 * 60.0; // 5 minutes

- (void)startVitalsPollingEvery:(NSTimeInterval)seconds {
    self.vitalsPollInterval = (seconds > 0) ? seconds : kVitalsPollIntervalSec;

    // make sure we accept incoming packets
    [self enableRealtimeCapture];

    // stop any existing timer
    [self stopVitalsPolling];

    // fire once immediately
    [self triggerVitalsMeasurementOnce];

    // then repeat
    self.vitalsPollTimer =
        [NSTimer scheduledTimerWithTimeInterval:self.vitalsPollInterval
                                         target:self
                                       selector:@selector(triggerVitalsMeasurementOnce)
                                       userInfo:nil
                                        repeats:YES];

    [[NSRunLoop mainRunLoop] addTimer:self.vitalsPollTimer forMode:NSRunLoopCommonModes];

    NSLog(@"[VITALS] polling started interval=%.0fs", self.vitalsPollInterval);
}

- (void)stopVitalsPolling {
    if (self.vitalsPollTimer) {
        [self.vitalsPollTimer invalidate];
        self.vitalsPollTimer = nil;
    }
    NSLog(@"[VITALS] polling stopped");
}

- (void)triggerVitalsMeasurementOnce {

    CE_HRControlCmd *hrStart = [[CE_HRControlCmd alloc] initWithOnoff:1 type:HR_CONTROL_TYPE_HR];
    [[CEProductK6 shareInstance] sendCmdToDevice:hrStart complete:nil];

    // HR
    CE_SyncHeartRateCmd *hr = [[CE_SyncHeartRateCmd alloc] init];
    hr.status = 1;
    [[CEProductK6 shareInstance] sendCmdToDevice:hr complete:nil];

    // SpO2
    CE_SyncHeartO2Cmd *o2 = [[CE_SyncHeartO2Cmd alloc] init];
    o2.status = 1;
    [[CEProductK6 shareInstance] sendCmdToDevice:o2 complete:nil];

    // Give the device time to produce packets BEFORE turning off.
    dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(75.0 * NSEC_PER_SEC)),
                   dispatch_get_main_queue(), ^{

        CE_SyncHeartRateCmd *hrOff = [[CE_SyncHeartRateCmd alloc] init];
        hrOff.status = 0;
        [[CEProductK6 shareInstance] sendCmdToDevice:hrOff complete:nil];

        CE_SyncHeartO2Cmd *o2Off = [[CE_SyncHeartO2Cmd alloc] init];
        o2Off.status = 0;
        [[CEProductK6 shareInstance] sendCmdToDevice:o2Off complete:nil];

        CE_HRControlCmd *hrStop = [[CE_HRControlCmd alloc] initWithOnoff:0 type:HR_CONTROL_TYPE_HR];
        [[CEProductK6 shareInstance] sendCmdToDevice:hrStop complete:nil];
    });

    NSLog(@"[VITALS] triggerVitalsMeasurementOnce sent (HR_CONTROL + HR/O2 ON)");
}


# pragma mark - Motion Watchdog

- (void)startMotionWatchdog {
    if (self.motionWatchdogTimer) return;

    dispatch_queue_t q = dispatch_get_global_queue(QOS_CLASS_UTILITY, 0);
    self.motionWatchdogTimer = dispatch_source_create(DISPATCH_SOURCE_TYPE_TIMER, 0, 0, q);

    dispatch_source_set_timer(self.motionWatchdogTimer,
                              dispatch_time(DISPATCH_TIME_NOW, 10 * NSEC_PER_SEC),
                              15 * NSEC_PER_SEC,
                              2 * NSEC_PER_SEC);

    __weak typeof(self) weakSelf = self;
    dispatch_source_set_event_handler(self.motionWatchdogTimer, ^{
        __strong typeof(weakSelf) self = weakSelf;
        if (!self) return;
        if (!self.recordingActive) return;
        if (!self.motionWindowActive) return;            // only enforce in motion phase
        if (!self.bleConnected) return;
        if (!self.nightSessionRunning) return;
        if (self.nightPhase != NightPhaseMotion) return;

        NSTimeInterval now = [[NSDate date] timeIntervalSince1970];

        // Less aggressive threshold (devices can pause)
        if (self.lastMotionPacketTs > 0 && (now - self.lastMotionPacketTs) > 60.0) {
            DLOG(@"[WATCHDOG] No MOTION144 for %.1fs -> restarting motion stream", now - self.lastMotionPacketTs);

            CE_SendMotionCmd *off = [[CE_SendMotionCmd alloc] init];
            off.onoff = 0;
            [self bleSendCmd:off label:@"Motion OFF (watchdog)"];

            dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(1.0 * NSEC_PER_SEC)),
                           dispatch_get_main_queue(), ^{
                if (!self.recordingActive) return;
                if (!self.motionWindowActive) return;
                if (!self.bleConnected) return;
                if (!self.nightSessionRunning) return;
                if (self.nightPhase != NightPhaseMotion) return;

                // Do NOT send CE_SensorCmd here; it causes command spam/disconnects
                CE_SendMotionCmd *on = [[CE_SendMotionCmd alloc] init];
                on.onoff = 1;
                [self bleSendCmd:on label:@"Motion ON (watchdog)"];
            });
        }
    });

    dispatch_resume(self.motionWatchdogTimer);
    DLOG(@"[WATCHDOG] started");
}

- (void)stopMotionWatchdog {
    if (!self.motionWatchdogTimer) return;
    dispatch_source_cancel(self.motionWatchdogTimer);
    self.motionWatchdogTimer = nil;
    DLOG(@"[WATCHDOG] stopped");
}


