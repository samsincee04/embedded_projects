- (NSString *)csvPathForType:(NSInteger)datatype {
    NSString *docs =
        NSSearchPathForDirectoriesInDomains(NSDocumentDirectory,
                                            NSUserDomainMask,
                                            YES).firstObject;

    switch (datatype) {
        case DATA_TYPE_MOTION_DATA:
            return [docs stringByAppendingPathComponent:
                [NSString stringWithFormat:@"motion_%@.csv",
                 self.currentSessionId ?: @"default"]];
            
        default:
            return nil;
    }
