    return [docs stringByAppendingPathComponent:
            [NSString stringWithFormat:@"combined_%@.txt", sid]];
}

- (NSString *)formatISO8601:(NSTimeInterval)ts {
    static NSDateFormatter *fmt = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        fmt = [[NSDateFormatter alloc] init];
        fmt.locale = [NSLocale localeWithLocaleIdentifier:@"en_US_POSIX"];
        fmt.timeZone = [NSTimeZone timeZoneWithAbbreviation:@"UTC"];
        fmt.dateFormat = @"yyyy-MM-dd'T'HH:mm:ss.SSS'Z'";
    });

    return [fmt stringFromDate:[NSDate dateWithTimeIntervalSince1970:ts]];
}

- (NSString *)formatTimestampMs:(NSTimeInterval)ts {
    static NSDateFormatter *fmt = nil;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        fmt = [[NSDateFormatter alloc] init];
        fmt.locale = [NSLocale localeWithLocaleIdentifier:@"en_US_POSIX"];
        fmt.timeZone = [NSTimeZone localTimeZone];
        fmt.dateFormat = @"yyyy-MM-dd HH:mm:ss.SSS";
    });
    return [fmt stringFromDate:[NSDate dateWithTimeIntervalSince1970:ts]];
}

- (void)appendCombinedRowWithTs:(NSTimeInterval)ts
                          cycle:(NSInteger)cycle
                           step:(NSString *)step
                            bpm:(NSString *)bpm
                         accelX:(NSString *)ax
                         accelY:(NSString *)ay
                         accelZ:(NSString *)az
                           spo2:(NSString *)spo2
{
    // Only write combined_*.txt during Start Night sessions
    if (![self shouldWriteCombinedRows]) return;

    // Capture immutable values for async block
    NSString *path = [self combinedPath];
    if (path.length == 0) return;

    NSString *tsStr = [self formatTimestampMs:ts];
    NSString *row = [NSString stringWithFormat:@"%@\t%ld\t%@\t%@\t%@\t%@\t%@\t%@\n",
                     tsStr,
                     (long)cycle,
                     step ?: @"-",
                     bpm  ?: @"-",
                     ax   ?: @"-",
                     ay   ?: @"-",
                     az   ?: @"-",
                     spo2 ?: @"-"];

    dispatch_queue_t q = self.fileIOQueue ?: dispatch_get_global_queue(QOS_CLASS_UTILITY, 0);

    dispatch_async(q, ^{
        // Re-check inside async to avoid writing after Stop Night
        if (![self shouldWriteCombinedRows]) return;

        // Ensure file exists + header written once (serialized by fileIOQueue)
        if (![[NSFileManager defaultManager] fileExistsAtPath:path]) {
            [kCombinedHeaderTSV writeToFile:path
                                 atomically:YES
                                   encoding:NSUTF8StringEncoding
                                      error:nil];
        }

        NSFileHandle *fh = [NSFileHandle fileHandleForWritingAtPath:path];
        if (!fh) return;

        [fh seekToEndOfFile];
        [fh writeData:[row dataUsingEncoding:NSUTF8StringEncoding]];
        [fh closeFile];
    });
}
#pragma mark - Session metadata writer

- (void)writeSessionMetadataWithEndTs:(NSTimeInterval)endTs {
    if (!self.currentSessionId || self.currentSessionId.length == 0) return;
    if (self.sessionStartTs <= 0) return;

    NSTimeInterval endTime = (endTs > 0) ? endTs : [[NSDate date] timeIntervalSince1970];

    NSDictionary *meta = @{
        @"patient_id": @"unknown",
        @"session_id": self.currentSessionId ?: @"",
        @"measurement_device": ([self hashedDeviceId] ?: @"R7 ring"),
        @"platform": @"ios",
        @"start_time": [self formatISO8601:self.sessionStartTs] ?: @"",
        @"end_time": [self formatISO8601:endTime] ?: @"",
        @"cycles": @((int)self.combinedCycle)
    };

    NSError *err = nil;
    NSData *data = [NSJSONSerialization dataWithJSONObject:meta
                                                   options:NSJSONWritingPrettyPrinted
                                                     error:&err];
    if (err || !data) {
        DLOG(@"[METADATA] Failed to build metadata JSON: %@", err);
        return;
    }

    NSString *json = [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
    NSString *filename = [NSString stringWithFormat:@"metadata_%@.json", self.currentSessionId];

    [self writeJSONString:json toFilename:filename];
    DLOG(@"[METADATA] Wrote %@", filename);
}
