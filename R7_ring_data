static const NSUInteger kMaxRealtimeSamples = 3600; // ~1 hour @ 1 sample/sec (adjust as you like)

- (void)appendRolling:(NSMutableArray<NSDictionary *> *)arr sample:(NSDictionary *)sample {
    if (!sample) return;
    @synchronized (arr) {
        [arr addObject:sample];
        if (arr.count > kMaxRealtimeSamples) {
            // drop oldest samples
            NSRange r = NSMakeRange(0, arr.count - kMaxRealtimeSamples);
            [arr removeObjectsInRange:r];
        }
    }
}

#pragma mark - Session Liveness Watchdog (Whole-loop stall recovery)

static const NSTimeInterval kSessionLivenessCheckEverySec = 60.0;
// If we receive *nothing* (motion OR vitals) for this long => soft reset
static const NSTimeInterval kSessionDeadAirThresholdSec  = 180.0; // 3 minutes

- (void)startSessionLivenessWatchdog {
    if (self.sessionWatchdogTimer) return;

    dispatch_queue_t q = dispatch_get_global_queue(QOS_CLASS_UTILITY, 0);
    self.sessionWatchdogTimer = dispatch_source_create(DISPATCH_SOURCE_TYPE_TIMER, 0, 0, q);

    dispatch_source_set_timer(self.sessionWatchdogTimer,
                              dispatch_time(DISPATCH_TIME_NOW, (int64_t)(kSessionLivenessCheckEverySec * NSEC_PER_SEC)),
                              (uint64_t)(kSessionLivenessCheckEverySec * NSEC_PER_SEC),
                              (uint64_t)(2 * NSEC_PER_SEC));

    __weak typeof(self) weakSelf = self;
    dispatch_source_set_event_handler(self.sessionWatchdogTimer, ^{
        __strong typeof(weakSelf) self = weakSelf;
        if (!self) return;

        // Only enforce when user intends the session to be running
        if (!self.wantNightRunning) return;
        if (!self.recordingActive) return;
        if (!self.bleConnected) return;

        // Avoid overlapping resets
        if (self.sessionResetInProgress) return;

        NSTimeInterval now = [[NSDate date] timeIntervalSince1970];

        // If we haven't seen any packets yet, don't punish immediately.
        // Give a short grace window after starting.
        if (self.lastAnyPacketTs <= 0) return;

        NSTimeInterval deadFor = now - self.lastAnyPacketTs;
        if (deadFor > kSessionDeadAirThresholdSec) {
            DLOG(@"[SESSION WATCHDOG] DEAD AIR for %.1fs (threshold %.1fs) -> soft reset loop",
                 deadFor, kSessionDeadAirThresholdSec);

            [self sessionSoftResetLoopWithReason:@"dead_air"];
        }
    });

    dispatch_resume(self.sessionWatchdogTimer);
    DLOG(@"[SESSION WATCHDOG] started (check=%.0fs threshold=%.0fs)",
         kSessionLivenessCheckEverySec, kSessionDeadAirThresholdSec);
}

- (void)stopSessionLivenessWatchdog {
    if (!self.sessionWatchdogTimer) return;
    dispatch_source_cancel(self.sessionWatchdogTimer);
    self.sessionWatchdogTimer = nil;
    DLOG(@"[SESSION WATCHDOG] stopped");
}

- (void)sessionSoftResetLoopWithReason:(NSString *)reason {
    if (self.sessionResetInProgress) return;
    self.sessionResetInProgress = YES;

    // Bump token so any scheduled phase steps self-cancel
    self.nightToken += 1;

    // Run reset on main to stay aligned with your dispatch_after scheduling
    dispatch_async(dispatch_get_main_queue(), ^{
        DLOG(@"[SESSION WATCHDOG] Soft reset begin reason=%@", reason ?: @"unknown");

        // stop the scheduler loop
        [self stopNightCycleTimer];

        // ensure motion OFF
        [self night_motion:NO];

        

        // reset packet timers so we don't instantly re-trigger
        self.lastMotionPacketTs = 0;
        self.lastVitalsPacketTs = 0;
        self.lastAnyPacketTs = [[NSDate date] timeIntervalSince1970];

        // 4) resync device state
        [self syncData];

        // 5) after a few seconds, restart the night loop
        dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(4.0 * NSEC_PER_SEC)),
                       dispatch_get_main_queue(), ^{
            if (!self.wantNightRunning || !self.recordingActive || !self.bleConnected) {
                DLOG(@"[SESSION WATCHDOG] Soft reset aborted (no longer running or disconnected)");
                self.sessionResetInProgress = NO;
                return;
            }

            DLOG(@"[SESSION WATCHDOG] Soft reset restart loop");
            [self startNightCycleTimer];

            // Release lock after loop restart
            self.sessionResetInProgress = NO;
        });
    });
}

- (void)startVitalsWatchdog {
    if (self.vitalsWatchdogTimer) return;

    dispatch_queue_t q = dispatch_get_global_queue(QOS_CLASS_UTILITY, 0);
    self.vitalsWatchdogTimer = dispatch_source_create(DISPATCH_SOURCE_TYPE_TIMER, 0, 0, q);

    // Check every 30s
    dispatch_source_set_timer(self.vitalsWatchdogTimer,
                              dispatch_time(DISPATCH_TIME_NOW, 30 * NSEC_PER_SEC),
                              30 * NSEC_PER_SEC,
                              2 * NSEC_PER_SEC);

    __weak typeof(self) weakSelf = self;
    dispatch_source_set_event_handler(self.vitalsWatchdogTimer, ^{
        __strong typeof(weakSelf) self = weakSelf;
        if (!self) return;

        // Only enforce during an active night session
        if (!self.wantNightRunning) return;
        if (!self.nightSessionRunning) return;
        if (!self.bleConnected) return;

        // Only enforce during vitals phases (SpO2 or HR)
        if (self.nightPhase == NightPhaseMotion) return;

        NSTimeInterval now = [[NSDate date] timeIntervalSince1970];
        if (self.lastVitalsPacketTs <= 0) return;

        // If nothing for 120s during a vitals phase,re-kick vitals streaming
        if ((now - self.lastVitalsPacketTs) > 120.0) {
            DLOG(@"[VITALS WATCHDOG] No HR/O2 packets for %.1fs -> re-kicking vitals ON",
                 (now - self.lastVitalsPacketTs));

            // do NOT stop vitals here.
            // Just re-send the ON commands to "kick" the firmware.
            dispatch_async(dispatch_get_main_queue(), ^{
                if (!self.wantNightRunning) return;
                if (!self.nightSessionRunning) return;
                if (!self.bleConnected) return;
                if (self.nightPhase == NightPhaseMotion) return;

                if (self.nightPhase == NightPhaseSpO2) {
                    [self night_spo2On];
                } else if (self.nightPhase == NightPhaseHR) {
                    [self night_hrOn];
                }
            });
        }
    });

    dispatch_resume(self.vitalsWatchdogTimer);
    DLOG(@"[VITALS WATCHDOG] started");
}

- (void)stopVitalsWatchdog {
    if (!self.vitalsWatchdogTimer) return;
    dispatch_source_cancel(self.vitalsWatchdogTimer);
    self.vitalsWatchdogTimer = nil;
    DLOG(@"[VITALS WATCHDOG] stopped");
}
