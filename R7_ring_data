// If YES: only motion logs should print
static const BOOL kLogOnlyMotion = NO;

// Night pipeline: SpO2 -> Motion -> HR (repeat)
static const NSTimeInterval kNightSpO2Seconds  = 40.0;
static const NSTimeInterval kNightMotionSeconds = 30.0;
static const NSTimeInterval kNightHRSeconds     = 40.0;

// Use this for any NON-motion log
#define DLOG(fmt, ...) do { if (!kLogOnlyMotion) NSLog((fmt), ##__VA_ARGS__); } while(0)

typedef NS_ENUM(NSInteger, NightPhase) {
    NightPhaseSpO2  = 0,
    NightPhaseMotion = 1,
    NightPhaseHR     = 2
};

@interface DataReceiver ()

// RX gating / session intent

/// Gate for processing vitals packets in receiveBleData (HR/O2).
/// When NO, HR/O2 packets are ignored even if the device is sending them.
/// During overnight streaming we keep this ON so we don't miss vitals.
@property (nonatomic, assign) BOOL realtimeCaptureEnabled;

