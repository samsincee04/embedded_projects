#pragma mark - Bluetooth Status

// Handles BLE connection / disconnection life cycle

- (void)bluetoothStatusChanged:(NSNotification *)noti {

    NSInteger status = [noti.object intValue];

    if (status == ProductStatus_completed) {
        self.bleConnected = YES;
        DLOG(@"[BLE] Connected");

        [[NSNotificationCenter defaultCenter] postNotificationName:@"BLE_CONNECTED_READY"
                                                            object:nil];

        [self stopSportMode];

        if (self.wantNightRunning) {
            DLOG(@"[BLE] Auto-resume night session after reconnect");

            self.recordingActive = YES;
            [self enableRealtimeCapture];

            CE_HRControlCmd *hrControlOn =
                [[CE_HRControlCmd alloc] initWithOnoff:1 type:HR_CONTROL_TYPE_HR];
            [self bleSendCmd:hrControlOn label:@"HR_CONTROL ON (reconnect)"];

            [self syncData];

            dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(3.0 * NSEC_PER_SEC)),
                           dispatch_get_main_queue(), ^{
                if (!self.recordingActive) return;
                [self startNightCycleTimer];
            });
        } else {
            DLOG(@"[BLE] Connected idle (wantNightRunning=NO)");
            [self startHeartbeat];
        }
        return;
    }

    if (status == ProductStatus_disconnected || status == ProductStatus_powerOff) {
        self.bleConnected = NO;
        DLOG(@"[BLE] Disconnected (segment %ld)", (long)self.motionSegmentId);

        [self stopNightCycleTimer];
        [self forceStopVitalsNow];
        self.motionWindowActive = NO;
        self.nightSessionRunning = NO;

        [self stopHeartbeat];
        [self stopMotionWatchdog];
        [self stopVitalsWatchdog];
        self.lastVitalsPacketTs = 0;
        [self stopSessionLivenessWatchdog];
        self.lastAnyPacketTs = 0;
        self.sessionResetInProgress = NO;

        self.recordingActive = NO;

        [self flushMotionBatch];

        self.motionSessionActive = NO;
        self.motionSessionStartTs = 0;
        self.lastFlushTs = 0;
        self.motionSampleCounter = 0;
        self.lastMotionPacketTs = 0;

        self.motionSegmentId++;
    }
}
- (void)syncData {
    
    // Performs hybrid device sync

    CE_SyncHybridCmd *cmd = [[CE_SyncHybridCmd alloc] init];

    CE_SensorCmd *sensorCmd = [[CE_SensorCmd alloc] init];
    sensorCmd.onoff = 1;

    CE_SyncPairOKCmd *pairOkCmd = [[CE_SyncPairOKCmd alloc] init];
    pairOkCmd.firstPairStatus = 0;

    cmd.infoItems = @[
        [self userInfoCmd],
        [self goalCmd],
        [[YD_SyncLanguageCmd alloc] initWithLanguage:0],
        [self timeCmd],
        sensorCmd,
        pairOkCmd
    ];

    DLOG(@"[SYNC] Sending hybrid sync");

    [[CEProductK6 shareInstance] sendCmdToDevice:cmd
                                       complete:^(NSError *error) {

        if (error) {
            DLOG(@"[SYNC] Error %@", error);
            return;
        }

        DLOG(@"[SYNC] Completed");

        dispatch_after(dispatch_time(DISPATCH_TIME_NOW, 2 * NSEC_PER_SEC),
                       dispatch_get_main_queue(), ^{
            
            [self startHeartbeat];
            
            [self stopSportMode];
            
            if (self.recordingActive) {
                // Do NOT start motion streaming here.
                // Night cycle will call night_motion(YES) only during Motion phase.

                self.motionSessionStartTs = [[NSDate date] timeIntervalSince1970];
                self.motionSessionActive = YES;
                self.lastFlushTs = 0;
                self.motionSampleCounter = 0;

                // lastMotionPacketTs should only advance when Motion phase is active
                self.lastMotionPacketTs = 0;
            } else {
                self.motionSessionActive = NO;
                self.motionSessionStartTs = 0;
                self.lastMotionPacketTs = 0;
            }

        });
    }];
}

#pragma mark - BLE Heartbeat

// Starts periodic lightweight BLE command, attempts to prevent device sleep/disconnect

- (void)startHeartbeat {
    if (self.heartbeatTimer) return;

    // Don’t heartbeat during night streaming; it collides with notifications/commands
    if (self.wantNightRunning || self.nightSessionRunning || self.recordingActive) {
        DLOG(@"[BLE] Heartbeat not started (streaming active)");
        return;
    }

    self.heartbeatTimer =
    [NSTimer scheduledTimerWithTimeInterval:60.0
                                     target:self
                                   selector:@selector(sendHeartbeat)
                                   userInfo:nil
                                    repeats:YES];

    DLOG(@"[BLE] Heartbeat started (60s)");
}

- (void)sendHeartbeat {
    // If you MUST ping, keep it rare and avoid “sensor on” spam during streaming.
    if (self.wantNightRunning || self.nightSessionRunning || self.recordingActive) return;
    if (!self.bleConnected) return;

    // If your SDK has a true ping/keepalive cmd, use that instead.
    // Otherwise, make this as harmless as possible.
    CE_SensorCmd *ping = [[CE_SensorCmd alloc] init];
    ping.onoff = 1;

    [self bleSendCmd:ping label:@"Heartbeat SensorCmd(1)"];
    DLOG(@"[BLE] Heartbeat ping sent");
}
    - (void)stopHeartbeat {
        [self.heartbeatTimer invalidate];
        self.heartbeatTimer = nil;
        DLOG(@"[BLE] Heartbeat stopped");
    }


- (nullable NSString *)exportSpO2HistoryToJSON {
    @synchronized (self.spo2HistoryJSON) {

        NSDictionary *json = @{
            @"type": @"spo2_history",
            @"exportTime": [NSDate date].description,
            @"count": @(self.spo2HistoryJSON.count),
            @"samples": self.spo2HistoryJSON ?: @[]
        };

        NSError *err = nil;
        NSData *data = [NSJSONSerialization dataWithJSONObject:json options:NSJSONWritingPrettyPrinted error:&err];
        if (err || !data) return nil;
        return [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
    }
}

- (nullable NSString *)exportHeartHistoryToJSON {
    @synchronized (self.heartHistoryJSON) {
        
        NSDictionary *json = @{
            @"type": @"heart_rate_history",
            @"exportTime": [NSDate date].description,
            @"count": @(self.heartHistoryJSON.count),
            @"samples": self.heartHistoryJSON ?: @[]
        };

        NSError *err = nil;
        NSData *data = [NSJSONSerialization dataWithJSONObject:json
                                                       options:NSJSONWritingPrettyPrinted
                                                         error:&err];
        if (err || !data) return nil;
        return [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
    }
}

- (nullable NSString *)exportAllRealtimeHistoryToJSON {
    @synchronized (self) {
        BOOL hasHR = self.heartHistoryJSON.count > 0;
        BOOL hasO2 = self.spo2HistoryJSON.count > 0;
        if (!hasHR && !hasO2) return nil;

        NSDictionary *json = @{
            @"type": @"realtime_history_bundle",
            @"exportTime": [NSDate date].description,
            @"heart_rate_count": @(self.heartHistoryJSON.count),
            @"spo2_count": @(self.spo2HistoryJSON.count),
            @"heart_rate_samples": self.heartHistoryJSON ?: @[],
            @"spo2_samples": self.spo2HistoryJSON ?: @[]
        };

        NSError *err = nil;
        NSData *data = [NSJSONSerialization dataWithJSONObject:json options:NSJSONWritingPrettyPrinted error:&err];
        if (err || !data) return nil;
        return [[NSString alloc] initWithData:data encoding:NSUTF8StringEncoding];
        
        
    }
}
